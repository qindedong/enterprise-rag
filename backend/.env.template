# ============================================================
# 企业级知识库 RAG 系统 — 环境变量配置模板
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env：cp .env.template .env
#   2. 编辑 .env，填写实际值
#   3. ⚠️ .env 文件包含敏感信息，请勿提交到 Git！
# ============================================================

# ===== 应用基础配置 =====
APP_NAME=企业知识库RAG
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM 配置 =====
# 支持任何 OpenAI Compatible API（OpenAI / 通义千问 / DeepSeek 等）
LLM_API_KEY=<your-llm-api-key>
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ===== Embedding 配置 =====
# 默认复用 LLM 的 API Key 和 Base URL
EMBEDDING_API_KEY=<your-embedding-api-key>
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072
EMBEDDING_BATCH_SIZE=32

# ===== Qdrant 向量数据库配置 =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_VECTOR_SIZE=3072

# ===== 安全配置 =====
# 用 openssl rand -hex 32 生成随机密钥
JWT_SECRET_KEY=<your-jwt-secret-key>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ===== 文件上传配置 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ===== RAG 参数配置 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=50
RERANK_TOP_K=10
